rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Permitir leitura pública de banners
    match /banners/{allPaths=**} {
      allow read: if true; // Leitura pública para todos
      allow write: if request.auth != null; // Escrita apenas para usuários autenticados
    }
    
    // Para outros arquivos, manter bloqueado por segurança
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
